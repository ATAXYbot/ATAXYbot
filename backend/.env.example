# NEETPrep official integration settings
NEETPREP_USE_OFFICIAL=true
NEETPREP_BASE_URL=https://www.neetprep.com
NEETPREP_OTP_URL=https://www.neetprep.com/api/auth/request-otp
NEETPREP_VERIFY_URL=https://www.neetprep.com/api/auth/verify-otp
NEETPREP_COURSE_DATA_URL=https://www.neetprep.com/api/user/courses
NEETPREP_OTP_METHOD=POST
NEETPREP_VERIFY_METHOD=POST
NEETPREP_COURSE_DATA_METHOD=GET
NEETPREP_OTP_BODY_TEMPLATE={"identifier":"__IDENTIFIER__"}
NEETPREP_VERIFY_BODY_TEMPLATE={"identifier":"__IDENTIFIER__","otp":"__OTP__"}
NEETPREP_COURSE_DATA_AUTH_HEADER=Authorization:Bearer __TOKEN__

# Cloudinary backup configuration
CLOUDINARY_CLOUD_NAME=ATAXY
CLOUDINARY_API_KEY=662266621129135
CLOUDINARY_API_SECRET=zFJj8H4aJzg5bMHXb4tA7iUY96I
CLOUDINARY_UPLOAD_FOLDER=ataxy/neetprep

# Cron schedule for weekly sync (default: Sunday 02:00)
SYNC_CRON=0 2 * * 0
